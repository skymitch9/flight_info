# ==============================================================
# Flight Deal Tracker — configuration
#
# Setup: copy this file to `.env` and fill in the values in the
# two REQUIRED sections below. Everything else is optional.
#
#   Windows:   copy .env.example .env
#   Mac/Linux: cp .env.example .env
# ==============================================================

# --- REQUIRED: Email notifications ---------------------------
# Gmail example. To get an app password:
#   1. Go to https://myaccount.google.com/security and enable 2-Step Verification
#   2. Go to https://myaccount.google.com/apppasswords and create one for "Mail"
#   3. Paste the 16-character password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
NOTIFICATION_EMAIL=your-email@gmail.com

# --- REQUIRED: Anthropic API key ------------------------------
# Get one at https://console.anthropic.com → API Keys
LLM_API_KEY=sk-ant-your-key-here
# Optional overrides (defaults shown):
#LLM_MODEL=claude-sonnet-4-6
#LLM_BASE_URL=https://api.anthropic.com/v1

# --- STRONGLY RECOMMENDED: real flight prices -----------------
# Sources are tried in this order (most reliable first); each one is
# optional, but configure at least one or the app runs on fake sample data.
# 1. SerpAPI — live Google Flights. Free: 250 searches/mo (https://serpapi.com)
SERPAPI_KEY=
# 2. SearchAPI.io — live Google Flights fallback. Free: 100 requests (https://www.searchapi.io)
SEARCHAPI_KEY=
# 3. Travelpayouts — free cached prices, last-resort fallback (https://www.travelpayouts.com)
TRAVELPAYOUTS_TOKEN=

# Monthly search budgets per source (0 = unlimited). When a source hits its
# budget it's skipped and the next fallback is used for the rest of the month.
#SERPAPI_MONTHLY_BUDGET=250
#SEARCHAPI_MONTHLY_BUDGET=100
#AMADEUS_MONTHLY_BUDGET=2000

# --- Optional: daily digest email -----------------------------
#DIGEST_ENABLED=true
#DIGEST_HOUR_UTC=17
#DIGEST_RESULT_COUNT=3
#DIGEST_REQUIRED_AIRLINES=DL
#DIGEST_NO_SAME_AIRLINE=true

# --- Optional: airline preferences ----------------------------
#PRIMARY_AIRLINES=DL
#SECONDARY_AIRLINES=AA,UA,WN
#SECONDARY_THRESHOLD=0.15
#TERTIARY_THRESHOLD=0.30
#PREMIUM_HIGHLIGHT_THRESHOLD=0.40

# --- Optional: how often to collect prices (hours) ------------
#COLLECTION_INTERVAL_HOURS=6

# --- Optional: API quota controls ------------------------------
# Each trip contributes up to MAX_DATES_PER_TRIP evenly spaced dates
# from its travel window; each route searches at most
# MAX_SEARCH_DATES_PER_ROUTE dates per collection cycle.
# Rough SerpAPI usage per cycle = routes × dates (× 3 extra daily for premium fares).
#MAX_DATES_PER_TRIP=3
#MAX_SEARCH_DATES_PER_ROUTE=6
# Airlines publish fares ~330 days out. Trips further ahead are "prepared"
# (no API usage) and tracking starts automatically once in range.
#BOOKING_HORIZON_DAYS=330

# Price snapshots older than this many days are pruned nightly (0 = keep all)
#SNAPSHOT_RETENTION_DAYS=180

# --- Optional: alternative flight data source -----------------
#AMADEUS_API_KEY=
#AMADEUS_API_SECRET=
#AMADEUS_PRODUCTION=false

# Database: leave this commented out when running with Docker —
# docker-compose points the app at the bundled Postgres container.
#DATABASE_URL=
